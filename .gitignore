node_modules
dist/
.DS_Store
*.log
logs/

# build artifacts — regenerated by `bun run build`, shipped via prepublishOnly
# (never needed in git history; npm publish bundles them from the fresh build)

# Runtime user state — strictly excluded
data/*
!data/.gitkeep
!data/settings.example.json

# Secrets — never commit
.env
.env.*
!.env.example
secrets/
*.pem
*.key

# Claude Code local state (contains per-user allow-lists, paths)
.claude/settings.local.json
.claude/*.local.*

# Editor / OS artefacts
.vscode/
.idea/
Thumbs.db

# Internal planning docs (not for public tracking)
plan.md
