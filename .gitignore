# ───────────────────────── Deps & build ─────────────────────────
node_modules/
dist/
# build artifacts — regenerated by `bun run build`, shipped via prepublishOnly
# (never needed in git history; npm publish bundles them from the fresh build)

# ───────────────────────── Runtime user state ─────────────────────────
# Strictly excluded. These contain real data (usage tokens, DB rows scanned
# from your projects/vault, GitHub traffic, agent sessions, memory entries)
# that must never leave the machine.
data/*
!data/.gitkeep
!data/settings.example.json

# Auth token file can appear under many names if code is ever refactored —
# catch them defensively at any depth.
auth-token
auth-token.*
*.auth-token

# ───────────────────────── Secrets ─────────────────────────
# Principle: secrets go through the OS keyring (see SECURITY.md), NEVER
# a file. These patterns are a belt-and-suspenders net in case a dev ever
# creates one by accident.
.env
.env.*
!.env.example
*.env
secrets/
*.secret
*.pem
*.key
*.p12
*.pfx
*.keystore
*.crt
*.cer
*.der
.npmrc
.yarnrc
.yarnrc.yml
credentials
credentials.*
*.credentials
gha-creds-*.json
service-account*.json

# ───────────────────────── Claude Code local state ─────────────────────────
# Contains per-user allow-lists, absolute paths, shell command patterns that
# pass auto-approval. Regenerated from user prompts over time.
.claude/settings.local.json
.claude/*.local.*
.claude/*.lock
.claude/shell-snapshots/
.claude/projects/
.claude/todos/

# ───────────────────────── AI coding tools ─────────────────────────
# Scratch files some editors/agents dump in the cwd. Frequently contain
# chat transcripts with absolute paths or pasted code snippets.
.aider*
.cursor/
.cursorignore
.continue/
.windsurf/
.zed/
.codeium/
.copilot/

# ───────────────────────── Editor / OS artefacts ─────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
.DocumentRevisions-V100
.fseventsd
.TemporaryItems
.VolumeIcon.icns
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# Editors (VS Code, JetBrains, Vim, Emacs, Sublime, Zed)
.vscode/
.vscode-test/
.idea/
.history/
.ionide/
*.swp
*.swo
*.swn
*~
Session.vim
.netrwhist
\#*\#
.\#*
*.sublime-workspace
*.sublime-project

# ───────────────────────── Caches & coverage ─────────────────────────
# Often contain full absolute paths — harmless but clutter and privacy-leaky.
*.tsbuildinfo
.eslintcache
.biome-cache
.turbo/
.vite/
.cache/
.parcel-cache/
coverage/
.nyc_output/

# ───────────────────────── Logs / temp / crash ─────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
*.pid
*.seed
*.pid.lock

# ───────────────────────── Pack / release artefacts ─────────────────────────
# `bun pm pack` and `npm pack` drop a tarball at repo root — regeneratable,
# should never be committed.
*.tgz
*.tar.gz
bun.lockb

# ───────────────────────── Merge conflicts ─────────────────────────
*.orig
*.rej
*.bak

# ───────────────────────── Tooling backups ─────────────────────────
# One-shot scripts (e.g. scripts/crop-mascot-sprites.ts) often save a
# pre-modification copy under `.backup-*/`. Keep it on disk for safety,
# don't ship.
**/.backup-*/
**/.backup-*

# ───────────────────────── Obsidian (if vault is ever sibling) ─────────────────────────
# Defensive: if a dev ever symlinks their vault into the project tree for
# quick testing, Obsidian's per-vault workspace state shouldn't follow.
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.trash/

# ───────────────────────── Internal planning ─────────────────────────
# Local-only design docs / notes that aren't part of the public project.
plan.md
TODO.local.md
NOTES.local.md

# ───────────────────────── Personal one-shot scripts ─────────────────────────
# Helper scripts that hardcode private paths (vault location, etc.) and are
# not generic enough to ship publicly. Keep them local; rewrite as
# parameterized scripts before considering a public version.
scripts/seed-vault-projects.ts

# ───────────────────────── Python (future adapters) ─────────────────────────
# Safety net if a future sub-project adds Python scripts.
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
